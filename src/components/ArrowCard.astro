---
import type { CollectionEntry } from "astro:content";
import { formatDate } from "@lib/utils";

type Props = {
  entry: CollectionEntry<"blog">;
}

const { entry } = Astro.props;
---

<a href={`/${entry.collection}/${entry.slug}`} class="group relative flex items-start gap-4 py-3 pr-8 rounded-lg hover:bg-[var(--bg-secondary)] transition-colors duration-300 ease-in-out -mx-3 px-3">
  <div class="absolute left-0 top-0 bottom-0 w-[2px] bg-accent origin-top scale-y-0 group-hover:scale-y-100 transition-transform duration-300 ease-out rounded-full"></div>
  <div class="flex flex-col flex-1 min-w-0">
    <div class="font-display text-content-primary leading-snug text-base">
      {entry.data.title}
    </div>
    <div class="text-sm text-content-secondary mt-0.5">
      {entry.data.description}
    </div>
    <div class="font-mono text-xs text-content-muted mt-1.5">
      {formatDate(entry.data.date)}
    </div>
  </div>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    class="shrink-0 mt-1 size-5 stroke-2 fill-none stroke-current text-content-muted group-hover:text-accent transition-colors duration-300">
    <line x1="5" y1="12" x2="19" y2="12" class="translate-x-3 group-hover:translate-x-0 scale-x-0 group-hover:scale-x-100 transition-transform duration-300 ease-in-out" />
    <polyline points="12 5 19 12 12 19" class="-translate-x-1 group-hover:translate-x-0 transition-transform duration-300 ease-in-out" />
  </svg>
</a>
