---
import { cn } from "@lib/utils";

type Props = {
  href: string;
  external?: boolean;
  underline?: boolean;
}

const { href, external, underline = true, ...rest } = Astro.props;
---

<a
  href={href}
  target={ external ? "_blank" : "_self" }
  class={cn(
    "inline-block text-content-secondary hover:text-accent transition-colors duration-300 ease-in-out",
    underline && "underline underline-offset-2 decoration-accent/30 hover:decoration-accent/60"
  )}
  {...rest}>
  <slot/>
</a>
