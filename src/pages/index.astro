---
import { getCollection } from "astro:content";
import Container from "@components/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import ArrowCard from "@components/ArrowCard.astro";
import Link from "@components/Link.astro";
import { SITE, HOME, SOCIALS } from "@consts";
import { books as allBooks } from "@lib/books";

const blog = (await getCollection("blog"))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0,SITE.NUM_POSTS_ON_HOMEPAGE);

const allwork = (await getCollection("work"))
  .sort((a, b) => new Date(b.data.dateStart).valueOf() - new Date(a.data.dateStart).valueOf());

const homepageCompanies = ["Etsy", "Writer", "Shopify", "HubSpot"];
const uniqueWork = allwork.filter((entry, i, arr) =>
  homepageCompanies.includes(entry.data.company) &&
  arr.findIndex(e => e.data.company === entry.data.company) === i
);

---

<PageLayout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <!-- Hero zone: Intro + Work -->
  <Container>
    <div class="space-y-12">
      <div class="space-y-6">
        <div>
          <h1 class="animate font-display italic text-4xl sm:text-5xl text-content-primary tracking-tight leading-[1.1]">
            Hi, I'm Mukul
          </h1>
          <div class="animate accent-line mt-4"></div>
        </div>
        <div class="space-y-4">
          <p class="animate font-mono text-sm text-content-muted tracking-tight">
            Staff Machine Learning Scientist — Etsy — NYC
          </p>
          <article>
            <p class="animate text-base leading-relaxed">
              I like finding and solving meaningful non-trivial problems at the intersection of research and application. I love building things from zero to one and prefer working with like-minded mission-driven people who care deeply about the societal impact of their work.
            </p>
            <p class="animate text-base leading-relaxed">
              Outside of work, I read and write quite a bit, dabble in photography, and have a weakness for anything with an engine. I am slowly — very slowly — working towards my pilot's licence.
            </p>
          </article>
        </div>
      </div>

      <section class="animate space-y-5">
        <div class="flex items-baseline gap-2">
          <h2 class="font-display text-xl text-content-primary">
            I've worked at
          </h2>
          <span class="text-accent/40">—</span>
          <Link href="/work">
            See details
          </Link>
        </div>
        <ul class="flex flex-wrap gap-6">
          {uniqueWork.map(entry => (
            entry.data.icon && (
              <li>
                <a href={entry.data.url || "/work"} target={entry.data.url ? "_blank" : "_self"} class="flex flex-col items-center gap-2 group">
                  <div class="w-12 h-12 rounded-xl bg-[var(--bg-secondary)] flex items-center justify-center group-hover:bg-[var(--bg-tertiary)] transition-colors duration-300">
                    <img
                      src={entry.data.icon}
                      alt={entry.data.company}
                      class="w-7 h-7 object-contain transition-all duration-300"
                    />
                  </div>
                  <span class="font-mono text-xs text-content-muted group-hover:text-content-secondary transition-colors text-center leading-tight">
                    {entry.data.company}
                  </span>
                  {typeof entry.data.dateEnd === "string" && entry.data.dateEnd.toLowerCase() === "current" && (
                    <span class="font-mono text-[10px] text-accent now-pulse">now</span>
                  )}
                </a>
              </li>
            )
          ))}
          <li>
            <a href="/work" class="flex flex-col items-center gap-2 group">
              <div class="w-12 h-12 rounded-xl bg-[var(--bg-secondary)] group-hover:bg-[var(--bg-tertiary)] transition-colors duration-300 flex items-center justify-center">
                <span class="text-content-muted text-lg tracking-widest">...</span>
              </div>
              <span class="font-mono text-xs text-content-muted group-hover:text-content-secondary transition-colors text-center leading-tight">
                & more
              </span>
            </a>
          </li>
        </ul>
      </section>
    </div>
  </Container>

  <!-- Content sections -->
  <Container>
    <div class="space-y-16 mt-28">
      <section class="animate space-y-6">
        <div class="flex flex-wrap gap-y-2 items-center justify-between">
          <h2 class="font-display text-xl text-content-primary">
            Things I've written
          </h2>
          <Link href="/blog">
            See all writing
          </Link>
        </div>
        <ul class="flex flex-col gap-4">
          {blog.map(post => (
            <li>
              <ArrowCard entry={post} />
            </li>
          ))}
        </ul>
      </section>

      <section class="animate space-y-4">
        <div>
          <h2 class="font-display text-xl text-content-primary">
            Books I recommend
          </h2>
          <p class="font-mono text-xs text-content-muted mt-1">"It is what you read when you don't have to that determines who you will be when you can't help it." — Oscar Wilde</p>
        </div>
        <ul id="book-list" data-books={JSON.stringify(allBooks)} class="grid grid-cols-1 sm:grid-cols-2 gap-x-10 gap-y-2.5">
          <li class="text-sm"><Link href="/books">See full list</Link></li>
        </ul>
      </section>

      <section class="animate space-y-5">
        <h2 class="font-display text-xl text-content-primary">
          Where I studied
        </h2>
        <ul class="flex flex-col space-y-4">
          <li class="flex gap-3 items-center">
            <div class="w-8 h-8 rounded-lg bg-[var(--bg-secondary)] flex items-center justify-center shrink-0">
              <img src="/work/gatech.png" alt="Georgia Institute of Technology" class="w-5 h-5 object-contain" />
            </div>
            <div>
              <div class="text-sm text-content-primary">
                Georgia Institute of Technology
              </div>
              <div class="font-mono text-xs text-content-muted">
                MS Computer Science — Machine Learning
              </div>
            </div>
          </li>
          <li class="flex gap-3 items-center">
            <div class="w-8 h-8 rounded-lg bg-[var(--bg-secondary)] flex items-center justify-center shrink-0">
              <img src="/work/rpi.png" alt="Rensselaer Polytechnic Institute" class="w-5 h-5 object-contain" />
            </div>
            <div>
              <div class="text-sm text-content-primary">
                Rensselaer Polytechnic Institute
              </div>
              <div class="font-mono text-xs text-content-muted">
                BS Computer Science — Minor in Business
              </div>
            </div>
          </li>
        </ul>
      </section>

      <section class="animate space-y-4">
        <h2 class="font-display text-xl text-content-primary">
          Say hi
        </h2>
        <article>
          <p>
            Always happy to talk about hard ML problems, interesting companies, or whatever you're building. Also up for conversations about photography, cars, politics, or a good book.
          </p>
        </article>
        <ul class="flex flex-wrap gap-2">
          {SOCIALS.map(SOCIAL => (
            <li class="flex gap-x-2 text-nowrap">
              <Link href={SOCIAL.HREF} external aria-label={`${SITE.NAME} on ${SOCIAL.NAME}`}>
                {SOCIAL.NAME}
              </Link>
              <span class="text-accent/40">/</span>
            </li>
          ))}
          <li class="text-nowrap">
            <a id="email-link" class="inline-block text-content-secondary hover:text-accent transition-colors duration-300 ease-in-out underline underline-offset-2 decoration-accent/30 hover:decoration-accent/60 cursor-pointer"></a>
          </li>
        </ul>
      </section>
    </div>
  </Container>
<script is:inline>
  var bookInterval = null;

  function initHomepage() {
    var u = 'mukul.surajiwale';
    var d = 'gmail.com';
    var el = document.getElementById('email-link');
    if (el && !el.href) {
      var addr = u + '@' + d;
      el.href = 'mailto:' + addr;
      el.textContent = addr;
    }

    var list = document.getElementById('book-list');
    if (!list) return;

    var allBooks = JSON.parse(list.getAttribute('data-books') || '[]');
    if (!allBooks.length) return;

    function shuffle(arr) {
      var a = arr.slice();
      for (var i = a.length - 1; i > 0; i--) {
        var j = Math.floor(Math.random() * (i + 1));
        var t = a[i]; a[i] = a[j]; a[j] = t;
      }
      return a;
    }

    function getBookItems() {
      return Array.from(list.querySelectorAll('[data-book]'));
    }

    function renderBooks(books) {
      var link = list.querySelector('[data-link]');
      getBookItems().forEach(function(el) { el.remove(); });
      books.forEach(function(b) {
        var li = document.createElement('li');
        li.className = 'text-sm book-item';
        li.setAttribute('data-book', '');
        li.style.opacity = '0';
        li.style.transition = 'opacity 0.4s ease';
        li.innerHTML = '<span class="text-content-primary">' + b.title + '</span><span class="text-content-muted text-xs">, ' + b.author + '</span>';
        list.insertBefore(li, link);
        // trigger reflow then fade in
        li.offsetHeight;
        li.style.opacity = '1';
      });
    }

    // Initial render
    var shuffled = shuffle(allBooks);
    var offset = 0;

    // Tag the link so we can find it
    var linkEl = list.firstElementChild;
    if (linkEl) linkEl.setAttribute('data-link', '');

    renderBooks(shuffled.slice(0, 5));
    offset = 5;

    // Cycle every 8 seconds
    if (bookInterval) clearInterval(bookInterval);
    bookInterval = setInterval(function() {
      // Fade out current
      var items = getBookItems();
      items.forEach(function(el) { el.style.opacity = '0'; });

      setTimeout(function() {
        // Get next 5
        var next = [];
        for (var i = 0; i < 5; i++) {
          if (offset >= shuffled.length) {
            shuffled = shuffle(allBooks);
            offset = 0;
          }
          next.push(shuffled[offset]);
          offset++;
        }
        renderBooks(next);
      }, 400);
    }, 8000);
  }

  initHomepage();
  document.addEventListener('astro:after-swap', initHomepage);
</script>
</PageLayout>
