---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import { dateRange } from "@lib/utils";
import { WORK } from "@consts";

const collection = (await getCollection("work"))
  .sort((a, b) => new Date(b.data.dateStart).valueOf() - new Date(a.data.dateStart).valueOf());

const work = await Promise.all(
  collection.map(async (item) => {
    const { Content } = await item.render();
    return { ...item, Content };
  })
);

// Group entries by company, preserving sort order
type WorkEntry = typeof work[number];
type GroupedWork = { company: string; icon?: string; roles: WorkEntry[] };

const grouped: GroupedWork[] = [];
const companyIndex = new Map<string, number>();

for (const entry of work) {
  const name = entry.data.company;
  if (companyIndex.has(name)) {
    grouped[companyIndex.get(name)!].roles.push(entry);
  } else {
    companyIndex.set(name, grouped.length);
    grouped.push({
      company: name,
      icon: entry.data.icon,
      roles: [entry],
    });
  }
}

// Year markers based on earliest role start at each company
const currentYear = new Date().getFullYear();
const groupYears = grouped.map(g => {
  const endDate = g.roles[0].data.dateEnd;
  if (typeof endDate === "string" && endDate.toLowerCase() === "current") return currentYear;
  const earliest = g.roles[g.roles.length - 1].data.dateStart;
  return new Date(earliest).getFullYear();
});

---

<PageLayout title={WORK.TITLE} description={WORK.DESCRIPTION}>
  <Container>
    <div class="space-y-10">
      <div class="animate flex items-baseline justify-between">
        <div class="font-display text-2xl text-content-primary">
          Work
        </div>
        <button id="toggle-all" class="font-mono text-xs text-content-muted hover:text-accent transition-colors duration-300">
          expand all
        </button>
      </div>

      <!-- Timeline -->
      <div class="relative">
        <!-- Gradient vertical line -->
        <div class="absolute left-[19px] top-0 bottom-0 w-px" style="background: linear-gradient(to bottom, var(--color-accent), var(--bg-tertiary) 40%, var(--bg-tertiary));" />

        <ul class="flex flex-col gap-3">
          {grouped.map((group, i) => {
            const showYear = i === 0 || groupYears[i] !== groupYears[i - 1];
            const entryId = `work-${i}`;
            const isSingle = group.roles.length === 1;

            return (
            <li class="animate relative">
              {/* Year marker */}
              {showYear && (
                <div class="absolute -left-12 top-[10px] font-mono text-xs text-content-muted opacity-60 select-none hidden sm:block">
                  {groupYears[i]}
                </div>
              )}

              {/* Company header row */}
              <div
                class="flex items-center gap-4 relative z-10 cursor-pointer rounded-lg -mx-2 px-2 py-1 hover:bg-[var(--bg-secondary)] transition-colors duration-200 timeline-toggle"
                role="button"
                aria-expanded="false"
                aria-controls={entryId}
                data-toggle-roles
              >
                {/* Logo node */}
                <div class:list={[
                  "w-10 h-10 rounded-full flex items-center justify-center shrink-0 overflow-hidden border-2 transition-all duration-300",
                  i === 0
                    ? "border-accent bg-accent/5 pulse-glow"
                    : "border-[var(--bg-tertiary)] bg-[var(--bg-secondary)]"
                ]}>
                  {group.icon ? (
                    <img
                      src={group.icon}
                      alt={group.company}
                      class="w-6 h-6 rounded-sm object-contain"
                    />
                  ) : (
                    <div class="w-3 h-3 rounded-full bg-content-muted" />
                  )}
                </div>
                <div class="flex-1 min-w-0">
                  <div class="font-semibold text-content-primary">
                    {group.company}
                  </div>
                  <div class="font-mono text-xs text-content-muted">
                    {isSingle
                      ? dateRange(group.roles[0].data.dateStart, group.roles[0].data.dateEnd)
                      : dateRange(
                          group.roles[group.roles.length - 1].data.dateStart,
                          group.roles[0].data.dateEnd
                        )
                    }
                    <span class="role-inline"> · {group.roles[0].data.role}</span>
                  </div>
                </div>
                {/* Chevron - close to content */}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-4 h-4 text-content-muted opacity-30 shrink-0 role-chevron" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </div>

              {/* Roles - collapsed by default */}
              <div id={entryId} class="ml-[19px] pl-[37px] border-l border-transparent role-details" data-expanded="false">
                {isSingle ? (
                  <div class="pt-1 pb-4 role-content">
                    <div class="text-sm font-medium text-content-primary role-title-expanded">
                      {group.roles[0].data.role}
                    </div>
                    <article class="text-sm text-content-muted role-description">
                      {(() => { const C = group.roles[0].Content; return <C />; })()}
                    </article>
                  </div>
                ) : (
                  <ul class="pt-1 pb-4 flex flex-col gap-2 role-content">
                    {group.roles.map((entry, j) => (
                      <li class="relative pl-4">
                        {/* Sub-node dot */}
                        <div class="absolute -left-[37px] top-[7px] w-full pointer-events-none">
                          <div class:list={[
                            "w-2 h-2 rounded-full -ml-[4px] ring-2 ring-[var(--bg-primary)]",
                            i === 0 && j === 0 ? "bg-accent" : "bg-content-muted"
                          ]} />
                        </div>
                        {/* Connector tick */}
                        <div class="absolute -left-[37px] top-[10px] w-[33px] h-px bg-[var(--bg-tertiary)]" />
                        <div class="text-sm font-medium text-content-primary">
                          {entry.data.role}
                        </div>
                        <div class="font-mono text-xs text-content-muted">
                          {dateRange(entry.data.dateStart, entry.data.dateEnd)}
                        </div>
                        <article class="text-sm text-content-muted role-description">
                          <entry.Content />
                        </article>
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            </li>
            );
          })}

        </ul>
      </div>
    </div>
  </Container>
</PageLayout>

<style>
  /* Pulse glow on current role */
  .pulse-glow {
    animation: pulse-accent 3s ease-in-out infinite;
  }

  @keyframes pulse-accent {
    0% {
      box-shadow: 0 0 0 0 color-mix(in srgb, var(--color-accent) 50%, transparent);
    }
    100% {
      box-shadow: 0 0 0 10px color-mix(in srgb, var(--color-accent) 0%, transparent);
    }
  }

  /* Chevron */
  .role-chevron {
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .timeline-toggle[aria-expanded="true"] .role-chevron {
    transform: rotate(180deg);
    opacity: 0.6;
  }

  .timeline-toggle[aria-expanded="true"] {
    background-color: var(--bg-secondary);
  }

  /* Hide inline role when expanded (single-role entries) */
  .timeline-toggle[aria-expanded="true"] .role-inline {
    display: none;
  }

  /* Expand/collapse descriptions */
  .role-description {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height 0.4s ease, opacity 0.3s ease;
  }

  .role-details[data-expanded="true"] .role-description {
    max-height: 300px;
    opacity: 1;
  }

  /* Hide expanded role title when collapsed (single-role entries) */
  .role-title-expanded {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height 0.3s ease, opacity 0.3s ease;
  }

  .role-details[data-expanded="true"] .role-title-expanded {
    max-height: 40px;
    opacity: 1;
  }

  /* Collapsed state: no space */
  .role-details[data-expanded="false"] .role-content {
    padding: 0;
    margin: 0;
    max-height: 0;
    overflow: hidden;
  }

  .role-details[data-expanded="true"] .role-content {
    max-height: 2000px;
    transition: max-height 0.4s ease;
  }
</style>

<script is:inline>
  (function() {
    function areAllExpanded() {
      var details = document.querySelectorAll('.role-details');
      if (!details.length) return false;
      for (var i = 0; i < details.length; i++) {
        if (details[i].getAttribute('data-expanded') !== 'true') return false;
      }
      return true;
    }

    function updateToggleAllLabel() {
      var btn = document.getElementById('toggle-all');
      if (btn) btn.textContent = areAllExpanded() ? 'collapse all' : 'expand all';
    }

    document.addEventListener('click', function(e) {
      // Individual toggle
      var toggle = e.target.closest('[data-toggle-roles]');
      if (toggle) {
        var details = document.getElementById(toggle.getAttribute('aria-controls'));
        if (!details) return;
        var expanded = details.getAttribute('data-expanded') === 'true';
        details.setAttribute('data-expanded', expanded ? 'false' : 'true');
        toggle.setAttribute('aria-expanded', expanded ? 'false' : 'true');
        updateToggleAllLabel();
        return;
      }

      // Toggle all
      if (e.target.id === 'toggle-all' || e.target.closest('#toggle-all')) {
        var allExpanded = areAllExpanded();
        var state = allExpanded ? 'false' : 'true';
        document.querySelectorAll('.role-details').forEach(function(d) {
          d.setAttribute('data-expanded', state);
        });
        document.querySelectorAll('[data-toggle-roles]').forEach(function(h) {
          h.setAttribute('aria-expanded', state);
        });
        updateToggleAllLabel();
      }
    });
  })();
</script>
