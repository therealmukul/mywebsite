---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import { dateRange } from "@lib/utils";
import { WORK } from "@consts";

const collection = (await getCollection("work"))
  .sort((a, b) => new Date(b.data.dateStart).valueOf() - new Date(a.data.dateStart).valueOf());

const work = await Promise.all(
  collection.map(async (item) => {
    const { Content } = await item.render();
    return { ...item, Content };
  })
);

// Group entries by company, preserving sort order
type WorkEntry = typeof work[number];
type GroupedWork = { company: string; icon?: string; roles: WorkEntry[] };

const grouped: GroupedWork[] = [];
const companyIndex = new Map<string, number>();

for (const entry of work) {
  const name = entry.data.company;
  if (companyIndex.has(name)) {
    grouped[companyIndex.get(name)!].roles.push(entry);
  } else {
    companyIndex.set(name, grouped.length);
    grouped.push({
      company: name,
      icon: entry.data.icon,
      roles: [entry],
    });
  }
}

// Compute year for each group (from most recent role's start)
const currentYear = new Date().getFullYear();
const groupYears = grouped.map(g => {
  const endDate = g.roles[0].data.dateEnd;
  if (typeof endDate === "string" && endDate.toLowerCase() === "current") return currentYear;
  return new Date(g.roles[0].data.dateStart).getFullYear();
});
const totalGroups = grouped.length;
---

<PageLayout title={WORK.TITLE} description={WORK.DESCRIPTION}>
  <Container>
    <div class="space-y-10">
      <div class="animate font-display text-2xl text-content-primary">
        Work
      </div>

      <!-- Timeline -->
      <div class="relative">
        <!-- Gradient vertical line: accent at top fading to muted -->
        <div class="absolute left-[19px] top-0 bottom-0 w-px" style="background: linear-gradient(to bottom, var(--color-accent), var(--bg-tertiary) 40%, var(--bg-tertiary));" />

        <ul class="flex flex-col">
          {grouped.map((group, i) => {
            const showYear = i === 0 || groupYears[i] !== groupYears[i - 1];
            const fadeLevel = Math.min(i / (totalGroups - 1), 1);

            return (
            <li class="animate relative">
              {/* Year marker */}
              {showYear && (
                <div class="absolute -left-12 top-[10px] font-mono text-xs text-content-muted opacity-60 select-none hidden sm:block">
                  {groupYears[i]}
                </div>
              )}

              {/* Company header row */}
              <div class="flex items-center gap-4 relative z-10 group cursor-pointer" data-toggle-roles>
                {/* Logo node */}
                <div class:list={[
                  "w-10 h-10 rounded-full flex items-center justify-center shrink-0 overflow-hidden border-2 transition-all duration-300",
                  i === 0
                    ? "border-accent bg-accent/5 pulse-glow"
                    : "border-[var(--bg-tertiary)] bg-[var(--bg-secondary)]"
                ]}>
                  {group.icon ? (
                    <img
                      src={group.icon}
                      alt={group.company}
                      class:list={[
                        "w-6 h-6 rounded-sm object-contain transition-all duration-300",
                        i > 0 && `opacity-${Math.round((1 - fadeLevel * 0.4) * 100)}`
                      ]}
                      style={i > 0 ? `filter: grayscale(${Math.round(fadeLevel * 40)}%)` : ""}
                    />
                  ) : (
                    <div class="w-3 h-3 rounded-full bg-content-muted" />
                  )}
                </div>
                <div class="flex-1">
                  <div class="font-semibold text-content-primary">
                    {group.company}
                  </div>
                  <div class="font-mono text-xs text-content-muted">
                    {group.roles.length > 1
                      ? dateRange(
                          group.roles[group.roles.length - 1].data.dateStart,
                          group.roles[0].data.dateEnd
                        )
                      : dateRange(group.roles[0].data.dateStart, group.roles[0].data.dateEnd)
                    }
                  </div>
                </div>
                {/* Expand indicator */}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-4 h-4 text-content-muted opacity-0 group-hover:opacity-60 transition-opacity duration-300 role-chevron">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </div>

              {/* Roles - collapsed by default, expanded on click */}
              <div class="ml-[19px] pl-[21px] border-l border-transparent role-details" data-expanded="true">
                {group.roles.length === 1 ? (
                  <div class="pt-2 pb-8 role-content">
                    <div class="text-sm font-medium text-content-primary opacity-80">
                      {group.roles[0].data.role}
                    </div>
                    <article class="mt-1 text-sm text-content-muted role-description">
                      {(() => { const C = group.roles[0].Content; return <C />; })()}
                    </article>
                  </div>
                ) : (
                  <ul class="pt-2 pb-8 flex flex-col gap-4 role-content">
                    {group.roles.map((entry, j) => (
                      <li class="relative pl-4">
                        {/* Sub-node dot */}
                        <div class="absolute -left-[21px] top-[7px] w-full pointer-events-none">
                          <div class:list={[
                            "w-2 h-2 rounded-full -ml-[4px] ring-2 ring-[var(--bg-primary)]",
                            i === 0 && j === 0 ? "bg-accent" : "bg-content-muted"
                          ]} />
                        </div>
                        {/* Connector tick */}
                        <div class="absolute -left-[21px] top-[10px] w-[17px] h-px bg-[var(--bg-tertiary)]" />
                        <div class="text-sm font-medium text-content-primary opacity-80">
                          {entry.data.role}
                        </div>
                        <div class="font-mono text-xs text-content-muted">
                          {dateRange(entry.data.dateStart, entry.data.dateEnd)}
                        </div>
                        <article class="mt-1 text-sm text-content-muted role-description">
                          <entry.Content />
                        </article>
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            </li>
            );
          })}

          {/* Terminal node */}
          <li class="relative z-10">
            <div class="absolute -top-16 left-[19px] w-px h-16 bg-gradient-to-b from-[var(--bg-tertiary)] to-transparent" />
            <div class="w-10 h-10 rounded-full bg-[var(--bg-secondary)] border-2 border-[var(--bg-tertiary)] flex items-center justify-center">
              <div class="w-2.5 h-2.5 rounded-full bg-content-muted" />
            </div>
          </li>
        </ul>
      </div>
    </div>
  </Container>
</PageLayout>

<style>
  /* 1. Pulse glow on current role */
  .pulse-glow {
    animation: pulse-accent 3s ease-in-out infinite;
  }

  @keyframes pulse-accent {
    0% {
      box-shadow: 0 0 0 0 color-mix(in srgb, var(--color-accent) 50%, transparent);
    }
    100% {
      box-shadow: 0 0 0 10px color-mix(in srgb, var(--color-accent) 0%, transparent);
    }
  }

  /* 2. Hover to reveal descriptions */
  .role-description {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height 0.4s ease, opacity 0.3s ease, margin 0.3s ease;
    margin-top: 0;
  }

  .role-details[data-expanded="true"] .role-description {
    max-height: 200px;
    opacity: 1;
    margin-top: 0.25rem;
  }

  .role-chevron {
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .role-details[data-expanded="false"] ~ .role-chevron,
  [data-expanded="false"] .role-chevron {
    transform: rotate(0deg);
  }

  [data-toggle-roles]:has(+ [data-expanded="true"]) .role-chevron {
    transform: rotate(180deg);
    opacity: 0.4;
  }
</style>

<script is:inline>
  function initTimeline() {
    document.querySelectorAll('[data-toggle-roles]').forEach(function(header) {
      header.addEventListener('click', function() {
        var details = this.nextElementSibling;
        if (!details || !details.classList.contains('role-details')) return;
        var expanded = details.getAttribute('data-expanded') === 'true';
        details.setAttribute('data-expanded', expanded ? 'false' : 'true');
      });
    });
  }
  document.addEventListener('DOMContentLoaded', initTimeline);
  document.addEventListener('astro:after-swap', initTimeline);
</script>
